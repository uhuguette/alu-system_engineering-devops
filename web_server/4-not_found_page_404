#!/usr/bin/env bash
# Update and install Nginx
sudo apt update
sudo apt install -y nginx

# Make sure Nginx is running
sudo systemctl enable nginx
sudo systemctl start nginx

# Backup default config
sudo cp /etc/nginx/sites-available/default /etc/nginx/sites-available/default.bak

# Create custom 404 page
CUSTOM_404_PAGE="/var/www/html/custom_404.html"
echo "Ceci n'est pas une page" | sudo tee $CUSTOM_404_PAGE > /dev/null

# Configure Nginx to use custom 404 page
sudo sed -i '/server_name _;/a \
    error_page 404 /custom_404.html;' /etc/nginx/sites-available/default

# Test Nginx configuration
sudo nginx -t

# Reload Nginx to apply changes
sudo systemctl reload nginx

echo "Nginx is configured with a custom 404 page at $CUSTOM_404_PAGE"